---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;
---

<li class="my-6" data-card-slug={id}>
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block text-lg font-medium text-accent",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
  </a>
  <Datetime {...props} />
  <p>{description}</p>
</li>

<script>
  import { getFromCache, getMultipleStats } from "@/utils/engagement";

  function fillCard(card: HTMLElement, views: number, likes: number) {
    const viewsEl = card.querySelector("[data-card-views]");
    const likesEl = card.querySelector("[data-card-likes]");
    if (viewsEl) viewsEl.textContent = String(views);
    if (likesEl) likesEl.textContent = String(likes);
  }

  async function loadCardStats() {
    const cards = document.querySelectorAll<HTMLElement>("[data-card-slug]");
    const uncachedSlugs: string[] = [];

    // 1단계: 캐시에서 즉시 표시
    for (const card of cards) {
      const slug = card.dataset.cardSlug;
      if (!slug) continue;

      const cached = getFromCache(slug);
      if (cached) {
        fillCard(card, cached.views, cached.likes);
      } else {
        uncachedSlugs.push(slug);
      }
    }

    // 2단계: 캐시에 없는 것만 Supabase에서 가져오기
    if (uncachedSlugs.length === 0) return;

    const statsMap = await getMultipleStats(uncachedSlugs);

    for (const card of cards) {
      const slug = card.dataset.cardSlug;
      if (!slug || !statsMap.has(slug)) continue;

      const stats = statsMap.get(slug)!;
      fillCard(card, stats.views, stats.likes);
    }
  }

  document.addEventListener("astro:page-load", loadCardStats);
</script>
